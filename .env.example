# agenteval-ovb – Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine API-Keys ein:
#   cp .env.example .env

# Pflicht: OpenAI API Key (platform.openai.com)
OPENAI_API_KEY=sk-...

# Modell für alle Evals (getestetes Modell + LLM-as-Judge)
MODEL_NAME=gpt-5.4-mini

# Optional: Mistral API Key – nur für make benchmark (console.mistral.ai)
# MISTRAL_API_KEY=...

# Optional: LangSmith Tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=...
