# agenteval-ovb – Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine API-Keys ein:
#   cp .env.example .env

# ── Agent (Standard-OpenAI-Endpunkt) ─────────────────────────────────────────
AGENT_API_KEY=sk-...
AGENT_MODEL_NAME=gpt-5.4-mini
# AGENT_API_BASE nur setzen für abweichenden Endpunkt (Azure, Ollama etc.)
AGENT_API_BASE=

# ── Weitere Agenten über OpenRouter ──────────────────────────────────────────
# Für Anthropic, Gemini, Llama etc.: OpenRouter als OpenAI-kompatibler Proxy.
# Den Modellnamen und api_base in agents.yaml konfigurieren, Key hier eintragen.
# OPENROUTER_API_KEY=sk-or-v1-...

# ── Judge (LLM-as-Judge für Evaluation) ──────────────────────────────────────
JUDGE_API_KEY=sk-...
JUDGE_MODEL_NAME=gpt-5.4-mini
# Für Judge über OpenRouter:
# JUDGE_API_BASE=https://openrouter.ai/api/v1
JUDGE_API_BASE=

# Optional: Mistral API Key – nur für make benchmark (console.mistral.ai)
# MISTRAL_API_KEY=...

# Optional: LangSmith Tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=...
