# agenteval-ovb – Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine API-Keys ein:
#   cp .env.example .env
# Einfacher: über die Web-App (start.bat) im Tab "API & Modelle" ausfüllen.

# ── Agent API-Keys (generisch, beliebig viele, anbieterunabhängig) ──────────
# Modell und api_base werden NICHT hier, sondern pro Agent in agents.yaml
# konfiguriert (api_base ist dort ein Pflichtfeld – auch für OpenAI).
AGENT_API_KEY_1=sk-...
# Weitere Keys einfach fortlaufend nummerieren:
# AGENT_API_KEY_2=sk-or-v1-...

# ── Judge (LLM-as-Judge für Evaluation) ──────────────────────────────────────
# Modell/api_base/provider_pin stehen im judge-Block in agents.yaml.
JUDGE_API_KEY=sk-...
