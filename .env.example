# agenteval-ovb – Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine API-Keys ein:
#   cp .env.example .env

# ── Agent (Standard-OpenAI-Endpunkt) ─────────────────────────────────────────
# Modell und Endpunkt (api_base) werden pro Agent in agents.yaml konfiguriert
# (api_base ist dort ein Pflichtfeld – auch für OpenAI).
AGENT_API_KEY=sk-...

# ── Weitere Agenten über OpenRouter ──────────────────────────────────────────
# Für Anthropic, Gemini, Llama etc.: OpenRouter als OpenAI-kompatibler Proxy.
# Modellname und api_base in agents.yaml konfigurieren, Key hier eintragen.
# OPENROUTER_API_KEY=sk-or-v1-...

# ── Judge (LLM-as-Judge für Evaluation) ──────────────────────────────────────
# Modell und Endpunkt (api_base) werden im judge-Block in agents.yaml
# konfiguriert (api_base ist dort ein Pflichtfeld).
JUDGE_API_KEY=sk-...

# ── Weitere Agenten mit eigenem Key (z. B. Mistral, ein zweiter OpenRouter-Key) ─
# Jeder Agent in agents.yaml verweist über api_key_env auf eine Variable hier –
# der Name ist frei wählbar. Einfach eine weitere Zeile ergänzen, z. B.:
# MISTRAL_API_KEY=...
# und in agents.yaml: api_key_env: MISTRAL_API_KEY
